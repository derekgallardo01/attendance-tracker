{
  "name": "attendance-tracker-e2e",
  "version": "1.0.0",
  "description": "Playwright smoke tests against live production for Attendance Tracker",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:ci": "playwright test --grep-invert \"Visual regression\"",
    "test:headed": "playwright test --headed",
    "test:debug": "PWDEBUG=1 playwright test",
    "test:visual": "playwright test --grep \"Visual regression\"",
    "update-snapshots": "playwright test --grep \"Visual regression\" --update-snapshots",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  }
}
